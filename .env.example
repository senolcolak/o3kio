# O3K Docker Compose Environment Variables
# Copy this file to .env and customize as needed

# ============================================
# O3K Configuration
# ============================================

# JWT secret for token signing (REQUIRED — generate with: openssl rand -base64 48)
O3K_JWT_SECRET=  # REQUIRED: generate with: openssl rand -base64 48

# Log level: debug, info, warn, error
O3K_LOG_LEVEL=info

# Log format: json, console
O3K_LOG_FORMAT=json

# ============================================
# Database Configuration
# ============================================

# PostgreSQL credentials
POSTGRES_DB=lightstack
POSTGRES_USER=lightstack
POSTGRES_PASSWORD=  # REQUIRED: set a strong password

# Full database URL (auto-constructed if not set)
# O3K_DB_URL=postgres://lightstack:PASSWORD@postgres:5432/lightstack?sslmode=disable

# ============================================
# Horizon Configuration
# ============================================

# OpenStack host (use 'o3k' for Docker Compose, 'host.docker.internal' for local O3K)
OPENSTACK_HOST=o3k

# Debug mode (set to False in production)
DEBUG=True

# Horizon image
# HORIZON_IMAGE=quay.io/openstack.kolla/horizon:2025.1-ubuntu-noble

# ============================================
# Network Configuration (Optional)
# ============================================

# Change these if default ports conflict with existing services

# Horizon ports
# HORIZON_HTTP_PORT=80
# HORIZON_HTTPS_PORT=443

# O3K API ports
# KEYSTONE_PORT=5000
# NOVA_PORT=8774
# NEUTRON_PORT=9696
# CINDER_PORT=8776
# GLANCE_PORT=9292
# METADATA_PORT=8775

# PostgreSQL port
# POSTGRES_PORT=5432

# ============================================
# Resource Limits (Optional)
# ============================================

# Uncomment to set resource limits for containers
# O3K_CPU_LIMIT=2
# O3K_MEMORY_LIMIT=4g
# POSTGRES_MEMORY_LIMIT=2g
# HORIZON_MEMORY_LIMIT=2g
