{
    "command": "rm -f /etc/apache2/sites-enabled/000-default.conf && /usr/sbin/apache2ctl -DFOREGROUND",
    "config_files": [
        {
            "source": "/var/lib/kolla/config_files/local_settings",
            "dest": "/etc/openstack-dashboard/local_settings.py",
            "owner": "horizon",
            "perm": "0644"
        },
        {
            "source": "/var/lib/kolla/config_files/horizon.conf",
            "dest": "/etc/apache2/sites-enabled/horizon.conf",
            "owner": "root",
            "perm": "0644"
        }
    ],
    "permissions": [
        {
            "path": "/var/log/kolla/horizon",
            "owner": "horizon:kolla",
            "recurse": true
        },
        {
            "path": "/var/log/apache2",
            "owner": "www-data:adm",
            "recurse": true
        },
        {
            "path": "/var/run/apache2",
            "owner": "www-data:www-data",
            "recurse": true
        },
        {
            "path": "/var/lib/kolla/venv/lib/python3.12/site-packages/static",
            "owner": "horizon:horizon",
            "recurse": true
        }
    ]
}
