{
    "command": "/usr/sbin/apache2ctl -DFOREGROUND",
    "config_files": [
        {
            "source": "/var/lib/kolla/config_files/horizon_settings.py",
            "dest": "/etc/openstack-dashboard/local_settings.d/_10_custom.py",
            "owner": "horizon",
            "perm": "0644",
            "optional": true
        }
    ],
    "permissions": [
        {
            "path": "/var/log/kolla/horizon",
            "owner": "horizon:horizon",
            "recurse": true
        },
        {
            "path": "/var/log/apache2",
            "owner": "www-data:www-data",
            "recurse": true,
            "optional": true
        }
    ]
}
